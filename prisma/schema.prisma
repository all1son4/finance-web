generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("FINANCE_POSTGRES_PRISMA_URL")
  directUrl = env("FINANCE_POSTGRES_URL_NON_POOLING")
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  budgets      Budget[]
  categories   Category[]
  members      Member[]
  savingsGoals SavingsGoal[]
  sessions     Session[]
  transactions Transaction[]
  workspaceMemberships WorkspaceMembership[]
}

model Workspace {
  id                String              @id @default(cuid())
  name              String
  inviteCode        String              @unique
  currency          String
  locale            String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  activeSessions    Session[]           @relation("ActiveWorkspaceSessions")
  budgets           Budget[]
  categories        Category[]
  members           Member[]
  memberships       WorkspaceMembership[]
  savingsGoals      SavingsGoal[]
  starterCategories StarterCategory[]
  transactions      Transaction[]
}

model WorkspaceMembership {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  role        String    @default("MEMBER")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([userId])
  @@index([workspaceId])
}

model StarterCategory {
  id          String    @id @default(cuid())
  workspaceId String
  name        String
  kind        String
  color       String
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
  @@index([workspaceId, sortOrder])
}

model Session {
  id                String     @id @default(cuid())
  userId            String
  activeWorkspaceId String?
  tokenHash         String     @unique
  expiresAt         DateTime
  createdAt         DateTime   @default(now())
  activeWorkspace   Workspace? @relation("ActiveWorkspaceSessions", fields: [activeWorkspaceId], references: [id], onDelete: SetNull)
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([activeWorkspaceId])
  @@index([userId])
}

model Member {
  id           String        @id @default(cuid())
  userId       String
  workspaceId  String
  name         String
  color        String
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
  @@index([userId])
  @@index([workspaceId])
}

model Category {
  id           String        @id @default(cuid())
  userId       String
  workspaceId  String
  name         String
  kind         String
  color        String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  budgets      Budget[]
  transactions Transaction[]
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace    Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
  @@index([userId, kind])
  @@index([workspaceId, kind])
}

model Transaction {
  id              String   @id @default(cuid())
  userId          String
  workspaceId     String
  memberId        String
  categoryId      String
  amount          Decimal
  transactionDate DateTime
  description     String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  category        Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  member          Member   @relation(fields: [memberId], references: [id], onDelete: Restrict)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([memberId])
  @@index([userId, transactionDate])
  @@index([workspaceId, transactionDate])
}

model Budget {
  id         String   @id @default(cuid())
  userId     String
  workspaceId String
  categoryId String
  name       String
  amount     Decimal
  startDate  DateTime
  endDate    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId, startDate, endDate])
  @@index([workspaceId, startDate, endDate])
}

model SavingsGoal {
  id            String    @id @default(cuid())
  userId        String
  workspaceId   String
  name          String
  targetAmount  Decimal
  currentAmount Decimal   @default(0)
  targetDate    DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId, targetDate])
  @@index([workspaceId, targetDate])
}
