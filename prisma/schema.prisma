generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url       = env("FINANCE_POSTGRES_PRISMA_URL")
  directUrl = env("FINANCE_POSTGRES_URL_NON_POOLING")
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  budgets      Budget[]
  categories   Category[]
  members      Member[]
  savingsGoals SavingsGoal[]
  sessions     Session[]
  settings     UserSettings?
  transactions Transaction[]
}

model UserSettings {
  id                String            @id @default(cuid())
  userId            String            @unique
  appName           String
  currency          String
  locale            String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  starterCategories StarterCategory[]
  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StarterCategory {
  id             String       @id @default(cuid())
  userSettingsId String
  name           String
  kind           String
  color          String
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  userSettings   UserSettings @relation(fields: [userSettingsId], references: [id], onDelete: Cascade)

  @@unique([userSettingsId, name])
  @@index([userSettingsId, sortOrder])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId])
}

model Member {
  id           String        @id @default(cuid())
  userId       String
  name         String
  color        String
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
}

model Category {
  id           String        @id @default(cuid())
  userId       String
  name         String
  kind         String
  color        String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  budgets      Budget[]
  transactions Transaction[]
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId, kind])
}

model Transaction {
  id              String   @id @default(cuid())
  userId          String
  memberId        String
  categoryId      String
  amount          Decimal
  transactionDate DateTime
  description     String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  category        Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  member          Member   @relation(fields: [memberId], references: [id], onDelete: Restrict)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([categoryId])
  @@index([memberId])
  @@index([userId, transactionDate])
}

model Budget {
  id         String   @id @default(cuid())
  userId     String
  categoryId String
  name       String
  amount     Decimal
  startDate  DateTime
  endDate    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startDate, endDate])
}

model SavingsGoal {
  id            String    @id @default(cuid())
  userId        String
  name          String
  targetAmount  Decimal
  currentAmount Decimal   @default(0)
  targetDate    DateTime?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, targetDate])
}
